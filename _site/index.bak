<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home - Freddy Friends</title>
    <link
      rel="icon"
      type="image/png"
      href="/assets/images/freddy_penguin.webp"
    />

    <link rel="stylesheet" href="/assets/build/main.css">
    <!-- <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>    
    <script src="/assets/js/tailwind-brand.js"></script> -->

    <style>
      @font-face {
        font-family: "Riley";
        src: url('/assets/fonts/RileyFont.ttf')
          format("truetype");
        font-weight: normal;
        font-style: normal;
      }
      .logo-font {
        font-family: "Riley", sans-serif;
      }
    </style>
    <link type="application/atom+xml" rel="alternate" href="http://localhost:4000/feed.xml" title="Freddy Friends" />

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  </head>
  <body class="bg-gray-50">
    

<!-- Modern Sticky Navigation -->
<nav class="sticky top-0 z-50 backdrop-blur-md bg-white/80 border-b border-gray-200/60">
    <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between h-20">

            <!-- Logo -->
            <div class="flex items-center space-x-3">
                <img src="/assets/images/freddy_penguin.webp"
                     alt="Logo"
                     class="h-9 w-auto">

                <a href="/"
                   class="text-5xl text-ink logo-font hover:text-brand-600 transition pt-2">
                    Freddy Friends
                </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center space-x-10 text-sm font-medium">

                <a href="/"
                class="relative text-gray-600 hover:text-ink transition group">
                    Home
                    <span class="absolute -bottom-2 left-0 w-0 h-0.5 bg-brand-500 transition-all group-hover:w-full"></span>
                </a>

                <a href="/updates/"
                class="relative text-gray-600 hover:text-ink transition group">
                    Updates
                    <span class="absolute -bottom-2 left-0 w-0 h-0.5 bg-brand-500 transition-all group-hover:w-full"></span>
                </a>

                <a href="/stories/"
                class="relative text-gray-600 hover:text-ink transition group">
                    Stories
                    <span class="absolute -bottom-2 left-0 w-0 h-0.5 bg-brand-500 transition-all group-hover:w-full"></span>
                </a>

                <a href="/gallery/"
                class="relative text-gray-600 hover:text-ink transition group">
                    Gallery
                    <span class="absolute -bottom-2 left-0 w-0 h-0.5 bg-brand-500 transition-all group-hover:w-full"></span>
                </a>


                <a href="/location/"
                class="relative text-gray-600 hover:text-ink transition group">
                    Location
                    <span class="absolute -bottom-2 left-0 w-0 h-0.5 bg-brand-500 transition-all group-hover:w-full"></span>
                </a>

                <a href="/about/"
                class="relative text-gray-600 hover:text-ink transition group">
                    About
                    <span class="absolute -bottom-2 left-0 w-0 h-0.5 bg-brand-500 transition-all group-hover:w-full"></span>
                </a>

            </div>

            <!-- Mobile Button -->
            <button id="hamburger"
                    class="md:hidden text-gray-600 hover:text-ink focus:outline-none transition">
                <svg class="w-6 h-6"
                     fill="none"
                     stroke="currentColor"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16">
                    </path>
                </svg>
            </button>

        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobileMenu"
         class="hidden md:hidden border-t border-gray-200/60 bg-white/95 backdrop-blur-md">
        <div class="px-6 py-6 space-y-5 text-base font-medium">

            <a href="/"
               class="block text-gray-700 hover:text-brand-600 transition">
                Home
            </a>

            <a href="/updates/"
               class="block text-gray-700 hover:text-brand-600 transition">
                Updates
            </a>

            <a href="/stories/"
               class="block text-gray-700 hover:text-brand-600 transition">
                Stories
            </a>

            <a href="/location/"
               class="block text-gray-700 hover:text-brand-600 transition">
                Location
            </a>

            <a href="/about/"
               class="block text-gray-700 hover:text-brand-600 transition">
                About
            </a>

        </div>
    </div>
</nav> <!-- Hero Section -->
<div class="relative w-full h-[36rem]">

    <!-- Background Image -->
    <img src="/assets/images/freddy-at-night.jpg"
         alt="Sailboat in beautiful blue water"
         class="absolute inset-0 w-full h-full object-cover">

    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/70"></div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-6xl mx-auto px-6 h-full flex flex-col justify-end pb-28">
        <h1 class="text-5xl md:text-6xl font-semibold tracking-tight text-white mb-6">
            Sailing Stories & Updates
        </h1>
        <p class="text-lg md:text-xl text-white/80 max-w-2xl">
            Cruising life, lessons learned, and adventures at sea.
        </p>
    </div>

    <!-- Circular Profile Image (Bottom Left Overlay) -->
    <div class="absolute left-8 md:left-16 bottom-0 translate-y-1/2 z-20">

        <div class="flex items-center space-x-5">

            <!-- Image -->
            <div class="relative">
                <img src="/assets/images/us.jpg"
                     alt="Blog authors"
                     class="w-28 h-28 md:w-36 md:h-36 rounded-full object-cover border-4 border-white shadow-xl">

                <!-- Optional soft ring effect -->
                <div class="absolute inset-0 rounded-full ring-4 ring-brand-100"></div>
            </div>

            
        </div>

    </div>

</div>

