---
layout: default
title: Home
---

<!-- Hero Section -->
<div class="relative w-full h-[36rem]">

    <!-- Background Image -->
    <img src="{{ '/assets/images/freddy-at-night.jpg' | relative_url }}"
         alt="Sailboat in beautiful blue water"
         class="absolute inset-0 w-full h-full object-cover">

    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/70"></div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-6xl mx-auto px-6 h-full flex flex-col justify-end pb-28">
        <h1 class="text-5xl md:text-6xl font-semibold tracking-tight text-white mb-6">
            Sailing Stories & Updates
        </h1>
        <p class="text-lg md:text-xl text-white/80 max-w-2xl">
            Cruising life, lessons learned, and adventures at sea.
        </p>
    </div>

    <!-- Circular Profile Image (Bottom Left Overlay) -->
    <div class="absolute left-8 md:left-16 bottom-0 translate-y-1/2 z-20">

        <div class="flex items-center space-x-5">

            <!-- Image -->
            <div class="relative">
                <img src="{{ '/assets/images/us.jpg' | relative_url }}"
                     alt="Blog authors"
                     class="w-28 h-28 md:w-36 md:h-36 rounded-full object-cover border-4 border-white shadow-xl">

                <!-- Optional soft ring effect -->
                <div class="absolute inset-0 rounded-full ring-4 ring-brand-100"></div>
            </div>

            
        </div>

    </div>

</div>

<!-- Main Content -->
<section class="max-w-6xl mx-auto px-6 pt-36 pb-28">

    <div class="flex flex-col lg:flex-row gap-16">

        <!-- Updates (Secondary Column) -->
        <aside class="lg:w-1/3">

            <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-500 mb-8">
                Latest Updates
            </h2>
<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
    </svg>
            <div class="space-y-6">
                {% assign sorted_updates = site.updates | sort: 'date' | reverse %}
                {% for update in sorted_updates %}

                <div class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 overflow-hidden">

                    {% if update.hero_image %}

                        {% assign images = site.static_files | where_exp: "file", "file.path contains update.hero_image" %}

                        {% if images.size > 0 %}
                            <div class="overflow-hidden">
                                <img src="{{ images[0].path }}"
                                    alt="{{ post.title}}"
                                    class="w-full h-40 object-cover object-center group-hover:scale-105 transition duration-500">
                            </div>
                        {% endif %}

                    {% endif %}



                        <!-- Content -->
                        <div class="p-6">
                            <p class="text-xs text-gray-400 mb-1">
                                {% include time-ago.html date=update.date %}
                            </p>

                            <h3 class="font-semibold text-ink mb-2 leading-snug">
                                {{ update.title }}
                            </h3>

                            <p class="text-gray-600 text-sm leading-relaxed">
                                {{ update.description }}
                            </p>
                        </div>


                </div>
                {% endfor %}
            </div>

        </aside>


        <!-- Stories (Primary Section) -->
        <div class="lg:w-2/3">

                        <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-500 mb-8">
                Stories
            </h2>

            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                {% assign sorted_stories = site.stories | sort: 'date' | reverse %}
                {% for post in sorted_stories limit:6 %}
                <article class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">

                    {% if post.hero_image %}

                        {% assign images = site.static_files | where_exp: "file", "file.path contains post.hero_image" %}

                        {% if images.size > 0 %}
                            <div class="overflow-hidden">
                                <img src="{{ images[0].path }}"
                                    alt="{{ post.title}}"
                                    class="w-full h-56 object-cover group-hover:scale-105 transition duration-500">
                            </div>
                        {% endif %}

                    {% endif %}


                    <div class="p-8">

                        <h3 class="text-xl font-semibold text-ink mb-3 leading-snug">
                            {{ post.title }}
                        </h3>

                        <p class="text-gray-600 mb-6 leading-relaxed">
                            {{ post.content | strip_html | truncatewords: 22 }}
                        </p>

                        <a href="{{ post.url | relative_url }}"
                           class="inline-flex items-center text-brand-600 font-medium group/link">
                            Read story
                            <svg class="w-4 h-4 ml-2 transition-transform group-hover/link:translate-x-1"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M9 5l7 7-7 7">
                                </path>
                            </svg>
                        </a>

                    </div>

                </article>
                {% endfor %}
            </div>

        </div>

    </div>

</section>